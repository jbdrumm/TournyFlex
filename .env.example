# Supabase
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Anthropic (server-side only via Netlify Function — never exposed to browser)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Commissioner PIN (6-8 digits recommended, e.g. 847291)
# Set this in Netlify Environment Variables — never commit to git
COMMISSIONER_PIN=your_commissioner_pin

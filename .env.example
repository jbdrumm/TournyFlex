# Neon Postgres (get this from your Neon project dashboard)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Anthropic (server-side only via Netlify Function)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Commissioner PIN (6-8 digits, set in Netlify Environment Variables)
COMMISSIONER_PIN=your_commissioner_pin
